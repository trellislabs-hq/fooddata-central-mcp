{
  "name": "@trellis-labs/fooddata-central-mcp",
  "version": "1.3.0",
  "description": "MCP server wrapping the USDA FoodData Central API — search and retrieve food nutrition data",
  "mcpName": "io.github.trellislabs-hq/fooddata-central-mcp",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "fooddata-central-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "test:eval": "node --import tsx --test eval/run.test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "usda",
    "fooddata",
    "nutrition",
    "food",
    "model-context-protocol"
  ],
  "author": "Trellis Labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/trellislabs-hq/fooddata-central-mcp.git"
  },
  "homepage": "https://github.com/trellislabs-hq/fooddata-central-mcp#readme",
  "bugs": {
    "url": "https://github.com/trellislabs-hq/fooddata-central-mcp/issues"
  },
  "files": [
    "dist/",
    "server.json",
    "README.md"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
